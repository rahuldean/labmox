# Required — set the master key to access LiteLLM admin UI
LITELLM_MASTER_KEY=sk-change-me

# Add your model API keys via LiteLLM admin UI at http://localhost:4000/ui

# Optional
# API_PORT=6000
# LITELLM_PORT=4000
# LITELLM_MODEL=inspector
# LITELLM_API_KEY=
# MAX_UPLOAD_MB=32

# LiteLLM Postgres — change the password for production
# LITELLM_DB_NAME=litellm
# LITELLM_DB_USER=llmproxy
# LITELLM_DB_PASSWORD=dbpassword9090
